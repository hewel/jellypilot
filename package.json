{
  "name": "jellypilot",
  "version": "1.4.1",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=20.17"
  },
  "scripts": {
    "dev": "rsbuild dev",
    "build": "rsbuild build",
    "dev:rsdoctor": "RSDOCTOR=true rsbuild",
    "build:rsdoctor": "RSDOCTOR=true rsbuild build",
    "preview": "rsbuild preview",
    "test": "rstest",
    "test:watch": "rstest --watch",
    "build:e2e": "tsx e2e/cli.ts build",
    "test:e2e": "tsx e2e/cli.ts test",
    "typecheck:e2e": "tsx e2e/cli.ts typecheck",
    "e2e": "bun run typecheck:e2e && bun run build:e2e && bun run test:e2e",
    "check:e2e-isolation": "tsx e2e/cli.ts isolation",
    "e2e:verify": "tsx e2e/cli.ts verify",
    "e2e:clean": "tsx e2e/cli.ts clean",
    "lint-staged": "lint-staged",
    "typecheck": "tsc --noEmit",
    "api": "bun scripts/media-server-api.mjs",
    "format": "oxfmt --write package.json tsconfig.json tests/tsconfig.json e2e/tsconfig.json '*.config.{js,json,jsonc,mjs,ts}' 'src/**/*.{css,js,jsx,json,jsonc,ts,tsx}' 'tests/**/*.{js,jsx,json,jsonc,ts,tsx}' 'e2e/**/*.{js,jsx,json,jsonc,ts,tsx}' 'scripts/**/*.mjs' 'src-tauri/**/*.json'",
    "format:check": "oxfmt --check package.json tsconfig.json tests/tsconfig.json e2e/tsconfig.json '*.config.{js,json,jsonc,mjs,ts}' 'src/**/*.{css,js,jsx,json,jsonc,ts,tsx}' 'tests/**/*.{js,jsx,json,jsonc,ts,tsx}' 'e2e/**/*.{js,jsx,json,jsonc,ts,tsx}' 'scripts/**/*.mjs' 'src-tauri/**/*.json'",
    "lint": "oxlint --deny-warnings --no-error-on-unmatched-pattern src tests e2e scripts rsbuild.config.ts rstest.config.ts rstest.setup.ts panda.config.ts postcss.config.mjs lint-staged.config.mjs",
    "lint:fix": "oxlint --fix --deny-warnings --no-error-on-unmatched-pattern src tests e2e scripts rsbuild.config.ts rstest.config.ts rstest.setup.ts panda.config.ts postcss.config.mjs lint-staged.config.mjs",
    "check": "bun run format:check && bun run lint && bun run check:styling-boundaries && bun run typecheck && bun run rust:fmt:check && bun run rust:clippy",
    "test:all": "bun run test && bun run rust:test",
    "prepare": "husky && bun run panda:codegen && effect-tsgo patch",
    "rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "rust:fmt:check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "rust:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "panda:codegen": "panda codegen --clean",
    "predev": "bun run panda:codegen",
    "predev:rsdoctor": "bun run panda:codegen",
    "prebuild": "bun run panda:codegen",
    "prebuild:rsdoctor": "bun run panda:codegen",
    "pretest": "bun run panda:codegen",
    "pretest:watch": "bun run panda:codegen",
    "pretypecheck": "bun run panda:codegen",
    "check:styling-boundaries": "bun scripts/check-styling-boundaries.mjs",
    "review:panda:tauri": "bun tauri dev --config src-tauri/tauri.panda-review.conf.json",
    "review:parity": "bun scripts/tauri-parity-review.mjs"
  },
  "dependencies": {
    "@ark-ui/solid": "^5.37.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@solid-devtools/overlay": "^0.33.5",
    "@tanstack/solid-form": "^1.33.0",
    "@tanstack/solid-query": "^5.101.0",
    "@tanstack/solid-router": "^1.170.16",
    "@tanstack/solid-virtual": "^3.13.29",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-store": "^2.4.3",
    "effect": "^4.0.0-beta.84",
    "lucide-solid": "^1.20.0",
    "solid-js": "^1.9.13"
  },
  "overrides": {
    "@wdio/native-utils": "2.5.0"
  },
  "devDependencies": {
    "@effect/tsgo": "0.23.0",
    "@openapitools/openapi-generator-cli": "^2.38.0",
    "@pandacss/dev": "1.11.4",
    "@rsbuild/core": "^2.0.15",
    "@rsbuild/plugin-babel": "^1.2.1",
    "@rsbuild/plugin-solid": "^1.2.2",
    "@rsdoctor/rspack-plugin": "^1.5.15",
    "@rstest/core": "^0.10.5",
    "@tanstack/router-plugin": "^1.168.18",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "@wdio/cli": "9.29.1",
    "@wdio/globals": "9.29.1",
    "@wdio/local-runner": "9.29.1",
    "@wdio/mocha-framework": "9.29.1",
    "@wdio/native-types": "2.4.0",
    "@wdio/spec-reporter": "9.29.1",
    "@wdio/tauri-plugin": "1.2.0",
    "@wdio/tauri-service": "1.2.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "tsx": "4.23.0",
    "typescript": "7.0.2",
    "webdriverio": "9.29.1"
  }
}
