{
  "name": "jellypilot",
  "version": "1.4.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.17"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "rsbuild dev",
    "build": "rsbuild build",
    "dev:rsdoctor": "RSDOCTOR=true rsbuild",
    "build:rsdoctor": "RSDOCTOR=true rsbuild build",
    "preview": "rsbuild preview",
    "test": "rstest",
    "test:watch": "rstest --watch",
    "lint-staged": "lint-staged",
    "build:webdriver": "bun scripts/build-webdriver-app.mjs",
    "test:e2e": "bun run build:webdriver && wdio run wdio.conf.ts",
    "typecheck": "tsc --noEmit",
    "api": "bun scripts/media-server-api.mjs",
    "atomic:check": "atomic-css check",
    "check:ui-cutover": "bun scripts/check-ui-cutover.mjs",
    "format": "oxfmt --write package.json tsconfig.json tests/tsconfig.json wdio.conf.ts '*.config.{js,json,jsonc,mjs,ts}' 'src/**/*.{css,js,jsx,json,jsonc,ts,tsx}' 'tests/**/*.{js,jsx,json,jsonc,ts,tsx}' 'scripts/**/*.mjs' 'src-tauri/**/*.json'",
    "format:check": "oxfmt --check package.json tsconfig.json tests/tsconfig.json wdio.conf.ts '*.config.{js,json,jsonc,mjs,ts}' 'src/**/*.{css,js,jsx,json,jsonc,ts,tsx}' 'tests/**/*.{js,jsx,json,jsonc,ts,tsx}' 'scripts/**/*.mjs' 'src-tauri/**/*.json'",
    "lint": "oxlint --deny-warnings --no-error-on-unmatched-pattern src tests scripts wdio.conf.ts rsbuild.config.ts rstest.config.ts rstest.setup.ts lint-staged.config.mjs",
    "lint:fix": "oxlint --fix --deny-warnings --no-error-on-unmatched-pattern src tests scripts wdio.conf.ts rsbuild.config.ts rstest.config.ts rstest.setup.ts lint-staged.config.mjs",
    "check": "bun run format:check && bun run lint && bun run check:ui-cutover && bun run atomic:check && bun run typecheck && bun run rust:fmt:check && bun run rust:clippy",
    "test:all": "bun run test && bun run rust:test",
    "atomic:build": "bun run --filter @jellypilot/atomic-css build",
    "atomic:test": "bun run --filter @jellypilot/atomic-css test",
    "ui:test": "bun run --filter @jellypilot/ui test",
    "ui:check": "bun run --filter @jellypilot/ui check:registry",
    "catalog:dev": "bun run --filter @jellypilot/catalog dev",
    "catalog:build": "bun run --filter @jellypilot/catalog build",
    "prepare": "husky",
    "rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "rust:fmt:check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "rust:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@jellypilot/ui": "workspace:*",
    "@solid-devtools/overlay": "^0.33.5",
    "@tanstack/solid-form": "^1.33.0",
    "@tanstack/solid-query": "^5.101.0",
    "@tanstack/solid-router": "^1.170.16",
    "@tanstack/solid-virtual": "^3.13.29",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@vanilla-extract/css": "1.20.1",
    "@vanilla-extract/recipes": "^0.5.7",
    "effect": "^4.0.0-beta.84",
    "lucide-solid": "^1.20.0",
    "solid-js": "^1.9.13"
  },
  "devDependencies": {
    "@axe-core/webdriverio": "^4.12.1",
    "@effect/language-service": "^0.86.2",
    "@jellypilot/atomic-css": "workspace:*",
    "@openapitools/openapi-generator-cli": "^2.38.0",
    "@rsbuild/core": "2.0.15",
    "@rsbuild/plugin-babel": "^1.2.1",
    "@rsbuild/plugin-solid": "^1.2.2",
    "@rsdoctor/rspack-plugin": "^1.5.15",
    "@rspack/core": "2.0.8",
    "@rstest/core": "^0.10.5",
    "@tanstack/router-plugin": "^1.168.18",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "@vanilla-extract/webpack-plugin": "2.3.27",
    "@wdio/cli": "^9.29.1",
    "@wdio/globals": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/native-types": "^2.4.0",
    "@wdio/native-utils": "2.5.0",
    "@wdio/spec-reporter": "^9.29.1",
    "@wdio/tauri-plugin": "^1.2.0",
    "@wdio/tauri-service": "^1.2.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "typescript": "^6.0.3",
    "webdriverio": "^9.29.1"
  },
  "overrides": {
    "@wdio/native-utils": "2.5.0"
  }
}
